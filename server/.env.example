# Server port
PORT=3001

# Environment
NODE_ENV=development

# PostgreSQL — Supabase pooled connection (port 6543) for application queries
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:6543/postgres

# PostgreSQL — Supabase direct connection (port 5432) for migrations only
DIRECT_DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Supabase project
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CORS — frontend origin
FRONTEND_URL=http://localhost:5173

# Email — Resend
RESEND_API_KEY=re_your-api-key

# Error monitoring — Sentry
SENTRY_DSN=https://your-dsn@sentry.io/your-project
